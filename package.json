{
	"name": "newman-reporter-ctrf-json",
	"version": "0.0.13-next-1",
	"description": "A Postman Newman JSON test reporter to create test results reports",
	"main": "dist/index.js",
	"scripts": {
		"build": "tsc",
		"test": "jest",
		"lint": "biome lint --write . --unsafe",
		"lint:check": "biome lint .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"all": "npm run lint && npm run format:check && npm run build && npm run check",
		"check": "biome check ."
	},
	"files": [
		"dist/",
		"README.md"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ctrf-io/newman-reporter-ctrf-json.git"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"homepage": "https://ctrf.io",
	"keywords": [
		"ctrf",
		"common-test-report-format",
		"test-reporting",
		"test-results",
		"testing",
		"json",
		"ci",
		"newman",
		"newman-reporter",
		"postman"
	],
	"author": "Matthew Poulton-White",
	"license": "MIT",
	"security": {
		"email": "security@ctrf.io",
		"url": "https://github.com/ctrf-io/.github/blob/main/SECURITY.md"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@types/jest": "30.0.0",
		"@types/newman": "5.3.6",
		"@types/node": "25.9.2",
		"jest": "30.4.2",
		"jest-ctrf-json-reporter": "0.0.11",
		"ts-jest": "29.4.11",
		"typescript": "5.9.3"
	},
	"dependencies": {
		"ctrf": "^0.2.0"
	}
}
